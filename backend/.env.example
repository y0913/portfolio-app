# Copy to .env (gitignored) for local Docker Compose dev.
# Production: set these via `fly secrets set <KEY>=<VALUE>`.

# --- Required in production ---
# DATABASE_URL is auto-injected by `fly postgres attach`. No need to set manually.
# DATABASE_URL=postgres://USER:PASS@HOST:5432/DB

# Rails encrypted credentials. Generate via `bin/rails credentials:edit` once,
# then upload the master key as a Fly secret.
# RAILS_MASTER_KEY=<contents of config/master.key>

# Hosts the app will accept (comma-separated). *.fly.dev is always allowed.
# ALLOWED_HOSTS=api.example.com

# CORS origins the frontend is served from (comma-separated).
# CORS_ORIGINS=https://portfolio-app.vercel.app,https://app.example.com

# --- AI provider selection ---
# Default in dev: stub (no real API calls). Switch to voyage / anthropic in prod
# once keys are set.
EMBEDDING_PROVIDER=stub
LLM_PROVIDER=stub

# --- AI provider keys (only needed when the corresponding *_PROVIDER is set) ---
# VOYAGE_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
